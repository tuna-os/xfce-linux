#!/bin/sh
# XFCE Wayland startup script

export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=XFCE
export GDK_BACKEND=wayland
export QT_QPA_PLATFORM=wayland
export CLUTTER_BACKEND=wayland
export MOZ_ENABLE_WAYLAND=1

# Use Mesa software renderer (llvmpipe) — no host GPU needed in VM
# Remove this line to use hardware GPU on real hardware
export LIBGL_ALWAYS_SOFTWARE=1

# Ensure XFCE libs in /usr/lib are found (ldconfig doesn't cache this dir on freedesktop-sdk)
export LD_LIBRARY_PATH=/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}

# XDG Config/Data paths
export XDG_CONFIG_DIRS="/etc/xdg:/usr/share/xfce4:/usr/local/share:/usr/share"
export XDG_DATA_DIRS="/usr/share/xfce4:/usr/local/share:/usr/share"

# Launch xfwl4 compositor (starts xfce4-session automatically)
exec xfwl4 --backend tty
