    <function name="panel_get_channel_name"
              c:identifier="xfce_panel_get_channel_name"
              version="4.8">
      <doc xml:space="preserve"
           filename="libxfce4panel/xfce-panel-convenience.c"
           line="115">Function for the name of the Xfconf channel used by the panel. By default
this returns "xfce4-panel", but you can override this value with the
environment variable XFCE_PANEL_CHANNEL_NAME.</doc>
      <source-position filename="libxfce4panel/xfce-panel-convenience.h"
                       line="40"/>
      <return-value transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libxfce4panel/xfce-panel-convenience.c"
             line="122">name of the Xfconf channel

See also: XFCE_PANEL_CHANNEL_NAME,
          xfce_panel_plugin_xfconf_channel_new and
          xfce_panel_plugin_get_property_base</doc>
        <type name="utf8" c:type="const gchar*"/>
      </return-value>
    </function>
    <function name="panel_pixbuf_from_source"
              c:identifier="xfce_panel_pixbuf_from_source"
              version="4.8">
      <doc xml:space="preserve"
           filename="libxfce4panel/xfce-panel-convenience.c"
           line="291">See xfce_panel_pixbuf_from_source_at_size</doc>
      <source-position filename="libxfce4panel/xfce-panel-convenience.h"
                       line="49"/>
      <return-value transfer-ownership="full">
        <doc xml:space="preserve"
             filename="libxfce4panel/xfce-panel-convenience.c"
             line="299">a GdkPixbuf or %NULL if nothing was found. The value should
         be released with g_object_unref when no longer used.

See also: XfcePanelImage</doc>
        <type name="GdkPixbuf.Pixbuf" c:type="GdkPixbuf*"/>
      </return-value>
      <parameters>
        <parameter name="source" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="293">string that contains the location of an icon</doc>
          <type name="utf8" c:type="const gchar*"/>
        </parameter>
        <parameter name="icon_theme"
                   transfer-ownership="none"
                   nullable="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="294">icon theme or %NULL to use the default icon theme</doc>
          <type name="Gtk.IconTheme" c:type="GtkIconTheme*"/>
        </parameter>
        <parameter name="size" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="295">size the icon that should be loaded</doc>
          <type name="gint" c:type="gint"/>
        </parameter>
      </parameters>
    </function>
    <function name="panel_pixbuf_from_source_at_size"
              c:identifier="xfce_panel_pixbuf_from_source_at_size"
              version="4.10">
      <doc xml:space="preserve"
           filename="libxfce4panel/xfce-panel-convenience.c"
           line="255">Try to load a pixbuf from a source string. The source could be
an abolute path, an icon name or a filename that points to a
file in the pixmaps directory.

This function is particularly usefull for loading names from
the Icon key of desktop files.

The pixbuf is never bigger than @dest_width and @dest_height.
If it is when loaded from the disk, the pixbuf is scaled
preserving the aspect ratio.</doc>
      <source-position filename="libxfce4panel/xfce-panel-convenience.h"
                       line="43"/>
      <return-value transfer-ownership="full">
        <doc xml:space="preserve"
             filename="libxfce4panel/xfce-panel-convenience.c"
             line="273">a GdkPixbuf or %NULL if nothing was found. The value should
         be released with g_object_unref when no longer used.

See also: XfcePanelImage</doc>
        <type name="GdkPixbuf.Pixbuf" c:type="GdkPixbuf*"/>
      </return-value>
      <parameters>
        <parameter name="source" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="257">string that contains the location of an icon</doc>
          <type name="utf8" c:type="const gchar*"/>
        </parameter>
        <parameter name="icon_theme"
                   transfer-ownership="none"
                   nullable="1"
                   allow-none="1">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="258">icon theme or %NULL to use the default icon theme</doc>
          <type name="Gtk.IconTheme" c:type="GtkIconTheme*"/>
        </parameter>
        <parameter name="dest_width" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="259">the maximum returned width of the GdkPixbuf</doc>
          <type name="gint" c:type="gint"/>
        </parameter>
        <parameter name="dest_height" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-convenience.c"
               line="260">the maximum returned height of the GdkPixbuf</doc>
          <type name="gint" c:type="gint"/>
        </parameter>
      </parameters>
    </function>
