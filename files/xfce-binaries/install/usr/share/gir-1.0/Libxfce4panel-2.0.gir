    <function name="panel_create_button"
              c:identifier="xfce_panel_create_button">
      <doc xml:space="preserve"
           filename="libxfce4panel/xfce-panel-convenience.c"
           line="42">Create regular #GtkButton with a few properties set to be useful in the
Xfce panel: Flat (%GTK_RELIEF_NONE), no focus on click and minimal padding.</doc>
      <source-position filename="libxfce4panel/xfce-panel-convenience.h"
                       line="34"/>
      <return-value transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libxfce4panel/xfce-panel-convenience.c"
             line="48">newly created #GtkButton.</doc>
        <type name="Gtk.Widget" c:type="GtkWidget*"/>
      </return-value>
    </function>
