    <callback name="PanelPluginPreInit"
              c:type="XfcePanelPluginPreInit"
              version="4.6">
      <doc xml:space="preserve"
           filename="libxfce4panel/xfce-panel-plugin.h"
           line="46">Callback function that is run in an external plugin before gtk_init(). It
should return %FALSE if the plugin is not available for whatever reason.
The function can be given as argument to one of the registration macros.

The main purpose of this callback is to allow multithreaded plugins to call
g_thread_init().</doc>
      <source-position filename="libxfce4panel/xfce-panel-plugin.h" line="62"/>
      <return-value transfer-ownership="none">
        <doc xml:space="preserve"
             filename="libxfce4panel/xfce-panel-plugin.h"
             line="58">%TRUE on success, %FALSE otherwise.</doc>
        <type name="gboolean" c:type="gboolean"/>
      </return-value>
      <parameters>
        <parameter name="argc" transfer-ownership="none">
          <doc xml:space="preserve"
               filename="libxfce4panel/xfce-panel-plugin.h"
               line="48">number of arguments to the plugin</doc>
          <type name="gint" c:type="gint"/>
