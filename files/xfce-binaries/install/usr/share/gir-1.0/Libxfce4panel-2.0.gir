                 filename="libxfce4panel/xfce-panel-plugin.c"
                 line="2558">a #GtkWidget relative to which the menu should be positioned.</doc>
            <type name="Gtk.Widget" c:type="GtkWidget*"/>
          </parameter>
          <parameter name="x"
                     direction="out"
                     caller-allocates="0"
                     transfer-ownership="full">
