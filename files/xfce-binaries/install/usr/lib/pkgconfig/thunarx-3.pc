prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

extensionsdir=${libdir}/thunarx-3

Name: thunarx
Description: A library to create Thunar extensions
Version: 4.21.5-dev
Requires.private: glib-2.0 >=  2.72.0, gio-2.0 >=  2.72.0, gmodule-2.0 >=  2.72.0, gtk+-3.0 >=  3.24.0, libxfce4util-1.0 >=  4.17.2
Libs: -L${libdir} -lthunarx-3
Cflags: -I${includedir}/thunarx-3
