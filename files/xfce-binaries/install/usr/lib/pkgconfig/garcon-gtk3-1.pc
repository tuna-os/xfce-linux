prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

garcon_api_version=1

Name: garcon-gtk
Description: Freedesktop.org compliant menu library
Version: 4.21.0-dev
Requires.private: garcon-1, glib-2.0 >=  2.72.0, gio-2.0 >=  2.72.0, gobject-2.0 >=  2.72.0, gthread-2.0 >=  2.72.0, gtk+-3.0 >=  3.24.0, libxfce4ui-2 >=  4.21.0, libxfce4util-1.0 >=  4.18.0
Libs: -L${libdir} -lgarcon-gtk3-1
Cflags: -I${includedir}/garcon-gtk3-1
