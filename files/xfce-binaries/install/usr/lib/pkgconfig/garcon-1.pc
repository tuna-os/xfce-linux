prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

garcon_api_version=1

Name: garcon
Description: Freedesktop.org compliant menu library
Version: 4.21.0-dev
Requires.private: glib-2.0 >=  2.72.0, gio-2.0 >=  2.72.0, gobject-2.0 >=  2.72.0, gthread-2.0 >=  2.72.0, libxfce4util-1.0 >=  4.18.0
Libs: -L${libdir} -lgarcon-1
Cflags: -I${includedir}/garcon-1
