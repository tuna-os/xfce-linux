prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

datarootdir=${prefix}/share
localedir=${datarootdir}/locale
api=2.0

Name: libxfce4panel
Description: Library for the Xfce Panel
Version: 4.21.1-dev
Requires.private: glib-2.0 >=  2.74.0, gmodule-2.0 >=  2.74.0, gtk+-3.0 >=  3.24.0, libxfce4ui-2 >=  4.21.3, libxfce4util-1.0 >=  4.18.0, gtk-layer-shell-0 >=  0.7.0
Libs: -L${libdir} -lxfce4panel-2.0
Libs.private: -lm
Cflags: -I${includedir}/xfce4/libxfce4panel-2.0
