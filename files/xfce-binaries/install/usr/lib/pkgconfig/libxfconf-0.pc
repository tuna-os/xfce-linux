prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

libxfconf_api_version=0

Name: xfconf
Description: Configuration library for Xfce
Version: 4.21.2
Requires.private: glib-2.0 >=  2.72.0, gio-unix-2.0 >=  2.72.0, gio-2.0 >=  2.72.0, gthread-2.0 >=  2.72.0, libxfce4util-1.0 >=  4.17.3
Libs: -L${libdir} -lxfconf-0
Cflags: -I${includedir}/xfce4/xfconf-0
