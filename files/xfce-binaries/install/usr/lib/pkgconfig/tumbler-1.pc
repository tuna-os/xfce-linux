prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

tumbler_api_version=1

Name: tumbler
Description: Supporting library for tumbler
Version: 4.21.1-dev
Requires.private: gdk-pixbuf-2.0 >=  2.42.8, glib-2.0 >=  2.72.0, gio-2.0 >=  2.72.0, gmodule-2.0 >=  2.72.0, gthread-2.0 >=  2.72.0, libxfce4util-1.0 >=  4.17.1
Libs: -L${libdir} -ltumbler-1
Libs.private: -lm
Cflags: -I${includedir}/tumbler-1
