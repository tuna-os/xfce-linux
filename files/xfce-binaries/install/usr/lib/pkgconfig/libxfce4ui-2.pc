prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib64

Name: libxfce4ui
Description: Widgets library for Xfce
Version: 4.21.7-dev
Requires.private: gio-unix-2.0 >=  2.72.0, gtk+-3.0 >=  3.24.0, gdk-pixbuf-2.0 >=  2.42.8, libxfce4util-1.0 >=  4.17.2, libxfconf-0 >=  4.12.0, gdk-x11-3.0 >=  3.24.0, x11 >=  1.6.7, sm >=  1.2.3, ice >=  1.0.10, libstartup-notification-1.0 >=  0.4
Libs: -L${libdir} -lxfce4ui-2
Libs.private: -lm
Cflags: -I${includedir}/xfce4/libxfce4ui-2
