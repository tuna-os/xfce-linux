prefix=/usr
exec_prefix=/usr
libdir=/usr/lib/x86_64-linux-gnu
includedir=/usr/include

Name: liblzma
Description: General purpose data compression library
License: 0BSD
URL: https://tukaani.org/xz/
Version: 5.8.3
Cflags: -I${includedir}
Cflags.private: -DLZMA_API_STATIC
Libs: -L${libdir} -llzma
Libs.private: -pthread -lpthread 
